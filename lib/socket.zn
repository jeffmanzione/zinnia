import io

self.SOCKET_ERROR = -1
self.AF_INET = 2
self.INADDR_ANY = 0
self.SOCK_STREAM = 1

__init()

function lookup_local_address() {
  return __lookup_local_address()
}

function create_server_socket(host, port) {
  return Socket(AF_INET, SOCK_STREAM, 0, host, port, True)
}

function create_client_socket(host, port) {
  return Socket(AF_INET, SOCK_STREAM, 0, host, port, False)
}

function cleanup() {
  __cleanup()
}

