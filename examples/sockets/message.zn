import io
import socket

host = args.host | socket.lookup_local_address()
port = Int(args.port) | 1453
message = args.message | i'Hello, world!'

server = () async {
  server_socket = socket.create_server_socket(host, port)
  handle = await server_socket.accept()
  await handle.send(message)
  handle.close()
  server_socket.close()
}()

client = () async {
  client = socket.create_client_socket(host, port)
  handle = await client.connect()
  io.println(await handle.receive())
  handle.close()
  client.close()
}()

await server
await client

socket.cleanup()
